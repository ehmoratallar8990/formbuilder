# =============================================================================
# .env.api — Backend (PHP/Laravel) configuration
# SECURITY: This file must NEVER be placed inside cms/ build context.
#            Never prefix vars here with VITE_ — they would leak into
#            the frontend build if this file were accessible to Vite.
# Copy to .env.api and fill in values before running.
# =============================================================================

# Application
APP_NAME="Form Builder"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=formbuilder
DB_USERNAME=formbuilder
DB_PASSWORD=secret

# Redis
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
CACHE_DRIVER=array
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Session
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

# OIDC (configurable provider — must support /.well-known/openid-configuration)
OIDC_ENABLED=false
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER_URL=
OIDC_REDIRECT_URI=http://localhost/api/auth/oauth/callback
OIDC_SCOPES="openid email profile"

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@formbuilder.local"
MAIL_FROM_NAME="${APP_NAME}"

# File Storage
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=

# Encryption key for webhook HMAC signatures
WEBHOOK_SECRET=

# Rate limiting defaults (requests per minute)
RATE_LIMIT_LOGIN=5
RATE_LIMIT_RENDER=100
