# =============================================================================
# .env.cms — Frontend (Vue.js / Vite) configuration
# SAFE: Only public, non-secret values here.
#       All vars MUST be prefixed VITE_ to be exposed to the browser.
#       Never put DB credentials, API keys, or secrets here.
# Copy to .env.cms and fill in values before running.
# =============================================================================

# API base URL — where the PHP backend is accessible from the browser
VITE_API_BASE_URL=http://localhost/api

# App metadata
VITE_APP_NAME="Form Builder"
VITE_APP_ENV=development
